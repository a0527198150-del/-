# YOUTUBE_API_KEY: Required for fetching channel videos via the official
# YouTube Data API v3 (replaces the old RSS/HTML-scraping approach).
# Get a key from https://console.cloud.google.com/apis/credentials
# after enabling "YouTube Data API v3" for your project.
# In CI, this is injected from the GitHub Actions secret YOUTUBE_API_KEY.
YOUTUBE_API_KEY=MY_YOUTUBE_API_KEY
